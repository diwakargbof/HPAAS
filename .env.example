# Postgres — the seed/demo setup expects a database named `hpas`
DATABASE_URL=postgres://admin:admin123@localhost:5432/hpas

# API server
API_PORT=4000
AUTH_SECRET=dev-secret-change-me
# Demo dashboard login password (real auth is a swap-in later; see apps/api/src/auth.ts)
DEMO_PASSWORD=demo

# AI generation — leave empty to use the deterministic mock provider (no network calls)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# WhatsApp adapter mode: "stub" records sends without any HTTP call.
# TODO: switch to "live" once Meta BSP approval lands and fill the credentials below.
WHATSAPP_MODE=stub
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev-verify-token

# Email adapter mode: "stub" | "resend"
EMAIL_MODE=stub
RESEND_API_KEY=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000
