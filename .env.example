# Postgres — the seed/demo setup expects a database named `hpas`.
# Local dev (e.g. a Docker Postgres container): plain connection string, no SSL.
DATABASE_URL=postgres://admin:admin123@localhost:5432/hpas

# --- Supabase (production) ---
# Use the pooled "Transaction" connection string (port 6543) as DATABASE_URL
# for the deployed app — serverless functions open many short-lived
# connections, and pgbouncer keeps that from exhausting Postgres.
#   DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations run DDL, which doesn't always work through a transaction-mode
# pooler — set DIRECT_DATABASE_URL to Supabase's direct connection (port
# 5432) and `pnpm db:migrate` / `pnpm db:seed` will prefer it automatically.
#   DIRECT_DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DIRECT_DATABASE_URL=

# API server
API_PORT=4000
AUTH_SECRET=dev-secret-change-me
# Demo dashboard login password (real auth is a swap-in later; see apps/api/src/auth.ts)
DEMO_PASSWORD=demo

# Required only when the API is deployed on Vercel: authorizes Vercel Cron
# to call the /api/cron/* endpoints (see apps/api/vercel.json). Generate a
# random value (e.g. `openssl rand -hex 32`) and set it in Vercel project
# settings too — with no value, every cron request is rejected.
CRON_SECRET=

# AI generation — leave empty to use the deterministic mock provider (no network calls)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# WhatsApp adapter mode: "stub" records sends without any HTTP call.
# TODO: switch to "live" once Meta BSP approval lands and fill the credentials below.
WHATSAPP_MODE=stub
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev-verify-token

# Email adapter mode: "stub" | "resend"
EMAIL_MODE=stub
RESEND_API_KEY=

# Dashboard — point this at the deployed API's URL in production
NEXT_PUBLIC_API_URL=http://localhost:4000
